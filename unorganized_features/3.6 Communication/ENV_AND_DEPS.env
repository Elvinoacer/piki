# ─────────────────────────────────────────────────────────────────────────────
# .env.local — Communication Feature Environment Variables
# Add these to your existing .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Pusher (Channels) ─────────────────────────────────────────────────────────
# Create a Channels app at https://dashboard.pusher.com
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap2                      # closest to Nairobi: ap2 (Singapore) or eu

# Public (safe to expose)
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── Africa's Talking ──────────────────────────────────────────────────────────
# Sign up at https://africastalking.com — use "sandbox" + "apikey" for dev
AT_USERNAME=sandbox                     # change to your username in production
AT_API_KEY=your_at_api_key
AT_SENDER_ID=PIKII                      # alphanumeric sender ID (apply via AT dashboard)
AT_MASK_FROM=+254XXXXXXXXX             # virtual number for voice masking (optional)

# ── Firebase / FCM ────────────────────────────────────────────────────────────
# Service account keys from Firebase Console → Project Settings → Service accounts
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----\n"

# ── Internal ──────────────────────────────────────────────────────────────────
# Random secret for server-to-server API calls (chat close, notification send)
INTERNAL_API_SECRET=change_me_to_a_secure_random_string

# ID of the "Pikii System" user used as sender for automated chat messages
# Create this user in your database seed (role: SYSTEM)
SYSTEM_USER_ID=cuid_of_system_user


# ─────────────────────────────────────────────────────────────────────────────
# package.json — add these dependencies
# Run: npm install pusher pusher-js firebase-admin africastalking date-fns zustand immer
# ─────────────────────────────────────────────────────────────────────────────
